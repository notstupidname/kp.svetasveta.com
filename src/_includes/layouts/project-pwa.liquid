{% unless title %}
  {% assign title = config.defaultTitle %}
{% endunless %}


{%- assign description = description | default: config.defaultDescription  -%}
{%- assign image = image | default: config.defaultImage -%}


<!doctype html>
<html lang="{{ config.lang }}">
  <head>
      {% include 'partials/head-pwa.liquid' pwaUrl: pwaUrl %}
  </head>
  <body class="is-loading project-pwa">
    {% include 'partials/header.liquid' %}
    {% include 'partials/nav-pwa.liquid' %}
    <main class="stack">
      <section class="title-card max">
        <header class="centered stack">
          <h1>{{ project-name }}</h1>
        </header>
        <a class="start" href={%- if content.length > 100 -%}"#plan"{%- else -%}"#concept-1"{%- endif -%}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000">
            <title>Старт</title>
            <path d="M500 50v900m0-900l300 300M500 50l-300 300" />
          </svg>
        </a>
      </section>
      {%- if content.length > 100 -%}
      <section id="plan" class="title-card title-svg max">
      {{ content |  remove: '<p>' |  remove: '</p>' }}
      </section>
      {% endif %}
      {% for room in concept %}
      <section id="concept-{{forloop.index}}" class="stack">
        <h2>{{room.name}}</h2>
        {% for pic in room.pics %}
          <figure>
            {% if pic.imgurl != "" %}
            {% respImageURL pic.imgurl pic.title "100vw" %}
            {% else %}
            {% include 'partials/img-placeholder.liquid' %}
            {% endif %}
          </figure>
        {% endfor %}
        <div class="items">
          {% for item in room.items %}
          {% if item.url != "" %}
          <a href="{{item.url}}" target="_blank">
            <figure>
              {% if item.imgurl != "" %}
              {% respImageURL item.imgurl item.title "45ch" %}
              {% else %}
              {% include 'partials/img-placeholder.liquid' %}
              {% endif %}
              <figcaption>{{item.title}}</figcaption>
            </figure>
          </a>
          {% else %}
          <figure>
            {% if item.imgurl != "" %}
            {% respImageURL item.imgurl item.title "45ch" %}
            {% else %}
            {% include 'partials/img-placeholder.liquid' %}
            {% endif %}
            <figcaption>{{item.title}}</figcaption>
          </figure>
          {% endif %}
          {% endfor %}
        </div>
      </section>
      {% endfor %}

      {% if makeProject %}
      {% for subcat in project %}
      {% if subcat[1].items.length > 0 %}
      <section id="project-{{subcat[0]}}" class="stack">
        <h2>{{ subcat[1].title }}</h2>
        {% for item in subcat[1].items %}
          <div class="card">
            {% if item.url != "" %}
            <a href="{{item.url}}" target="_blank">
              {% if item.imgurl != "" %}
              {% respImageURL item.imgurl item.title "45ch" %}
              {% else %}
              {% include 'partials/img-placeholder.liquid' %}
              {% endif %}
            </a>
            {% else %}
            {% if item.imgurl != "" %}
            {% respImageURL item.imgurl item.title "45ch" %}
            {% else %}
            {% include 'partials/img-placeholder.liquid' %}
            {% endif %}
            {% endif %}
            <div class="card-text">
              <p>{{item.title}}</p>
              <p>{{item.details}}</p>
            </div>
            <p>{{item.count | append: " "}}{% if item.edizm != "" %}{{item.edizm}}{% else %}шт{% endif %}</p>
          </div>
        {% endfor %}
      </section>
      {% endif %}
      {% endfor %}
      {% endif %}
    </main>
    {% include 'partials/footer.liquid' %}
  </body>
</html>
